# Required
RESEND_API_KEY=re_...
NOTIFY_EMAIL=you@yourdomain.com

# Optional: sender (use a verified domain in production)
FROM_EMAIL=webhooks@onresend.dev

# Optional: HMAC signature verification (per-provider). When set, every request
# must carry a valid signature. Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=long-random-string-for-hmac

# Optional: fan-out channels (best effort, never block email delivery)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Optional: retry queue and dead-letter inbox
DEAD_LETTER_FILE=./data/dead-letter.jsonl
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=30000

# Optional: server
PORT=3000
